{
  "name": "vault-fetch",
  "version": "0.1.0",
  "description": "Fetch JS-rendered web pages with Playwright and save as Markdown to Obsidian Vault",
  "type": "module",
  "license": "MIT",
  "author": "driller",
  "repository": {
    "type": "git",
    "url": "https://github.com/drillan/vault-fetch.git"
  },
  "keywords": [
    "obsidian",
    "playwright",
    "markdown",
    "web-clipper",
    "readability",
    "cli"
  ],
  "files": [
    "dist"
  ],
  "bin": {
    "vault-fetch": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@types/turndown": "^5.0.6",
    "eslint": "^10.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
